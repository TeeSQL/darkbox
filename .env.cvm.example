# DarkBox CVM core defaults. Copy to .env and override per deployment.

HIDDEN_CHAIN_ID=88813
ANVIL_BLOCK_TIME=1
ANVIL_EXTRA_ARGS=

AGENT_STRATEGY=random
AGENT_KIND=random-mixed
AGENT_COUNT=3
AGENT_TURNS=0
AGENT_RUN_ID=cvm-v0
MIN_WORKERS=2
MAX_WORKERS=8
TARGET_TURNS_PER_MINUTE=20
MIN_AGENT_INTERVAL_MS=30000
MAX_AGENT_INTERVAL_MS=900000
SCHEDULER_TICK_MS=2000
JITTER_PCT=30
MAX_IN_FLIGHT_PER_AGENT=1

# Set only inside the CVM/secret manager when using Venice.
VENICE_API_KEY=
VENICE_MODEL=venice-grok-41-fast

# Public/API services.
TELEGRAM_BOT_TOKEN=
ALLOW_INSECURE_DEV_AUTH=false
STT_MODE=stub
STT_URL=
STT_API_KEY=
STT_MODEL=whisper-1
TRANSCRIBER_RETENTION_MS=900000

# Bridge/signer are intentionally not part of the default core deploy yet.
BRIDGE_ADDRESS=0x0000000000000000000000000000000000000000
PUBLIC_CHAIN_ID=8453
WITHDRAWALS_ENABLED=false
SIGNER_PRIVATE_KEY=
SIGNER_BRIDGE_TOKEN=

# Market approval bot (ops profile)
# Bot posts market proposals to the DarkBox approval topic with Approve/Deny buttons.
MARKET_APPROVAL_BOT_TOKEN=
MARKET_APPROVAL_CHAT_ID=-1003946790386
MARKET_APPROVAL_THREAD_ID=894
MARKET_APPROVAL_ADMIN_USER_IDS=475212779
