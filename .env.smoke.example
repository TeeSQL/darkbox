# ---------------------------------------------------------------------------
# DarkBox deposit/withdrawal smoke test — testnet config
# Copy to .env.smoke and fill in. Do NOT commit a filled copy (.env* is ignored).
#
# Model: the PUBLIC bridge runs on a real testnet; the SHADOW controller runs on
# a local anvil that scripts/smoke-testnet.sh boots for you. So the only thing
# that needs real testnet gas is ONE funded key.
# ---------------------------------------------------------------------------

# Public testnet RPC + chain id (default: Base Sepolia).
PUBLIC_RPC_URL=https://sepolia.base.org
PUBLIC_CHAIN_ID=84532

# A funded key on that testnet. Used to deploy the bridge + a mintable test
# USDC, and to act as the depositing/withdrawing user. Needs testnet ETH for
# gas only (test USDC is minted by the deploy, no USDC faucet required).
# Get Base Sepolia ETH: https://docs.base.org/tools/network-faucets
DEPLOYER_PRIVATE_KEY=

# Optional — override the withdrawal recipient (default: the deployer).
# RECIPIENT_ADDRESS=

# Optional — amounts in whole USDC.
# AMOUNT_USDC=100
# WITHDRAW_USDC=40
