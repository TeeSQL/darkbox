{
  "name": "darkbox",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "docker compose up --build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm run test:ts && pnpm run test:contracts",
    "test:ts": "pnpm --filter @darkbox/shared --filter @darkbox/bridge test",
    "test:contracts": "pnpm --filter @darkbox/contracts run setup && pnpm --filter @darkbox/contracts run test"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
