{
  "name": "@darkbox/indexer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "node --import tsx src/index.ts",
    "ingest:ethglobal": "node --import tsx src/ethglobal/cli.ts",
    "ingest:ethglobal:prod": "node dist/services/indexer/src/ethglobal/cli.js",
    "lifecycle": "node --import tsx src/marketLifecycleCli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@darkbox/shared": "workspace:*",
    "@fastify/sensible": "^6.0.3",
    "fastify": "^5.3.3",
    "pg": "^8.13.3",
    "viem": "^2.21.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.13"
  }
}
