{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@darkbox/shared": [
        "packages/shared/src/index.ts"
      ],
      "@darkbox/shared/*": [
        "packages/shared/src/*"
      ]
    },
    "ignoreDeprecations": "6.0",
    "types": [
      "node"
    ]
  }
}
